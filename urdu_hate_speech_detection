{"cell_type":"markdown","source":"---\n## Cell 1 — Install Dependencies & Imports","metadata":{}},{"cell_type":"code","source":" \n\n# Kaggle already ships most packages; only install extras if missing.\nimport subprocess, sys\ndef _pip(*pkgs):\n    subprocess.run([sys.executable, '-m', 'pip', 'install', '--quiet', *pkgs], check=False)\n\ntry:\n    import regex\nexcept ImportError:\n    _pip('regex')\ntry:\n    from deep_translator import GoogleTranslator\nexcept ImportError:\n    _pip('deep-translator')\ntry:\n    from langdetect import detect\nexcept ImportError:\n    _pip('langdetect')\n\nimport os\nimport concurrent.futures\nfrom collections import Counter\nimport pandas as pd\nimport numpy as np\nimport regex as re\nimport matplotlib.pyplot as plt\nimport seaborn as sns\n\nimport torch\nimport torch.nn as nn\nimport torch.nn.functional as F\nfrom torch.optim import AdamW\nfrom torch.utils.data import DataLoader, TensorDataset\n\nfrom transformers import (\n    BertTokenizer, BertForSequenceClassification,\n    XLMRobertaTokenizer, XLMRobertaForSequenceClassification,\n    get_linear_schedule_with_warmup,\n)\n\nfrom sklearn.model_selection import train_test_split\nfrom sklearn.feature_extraction.text import TfidfVectorizer\nfrom sklearn.svm import SVC\nfrom sklearn.linear_model import LogisticRegression\nfrom sklearn.ensemble import RandomForestClassifier\nfrom sklearn.tree import DecisionTreeClassifier\nfrom sklearn.metrics import (\n    f1_score, accuracy_score, precision_score, recall_score,\n    confusion_matrix, precision_recall_curve, auc,\n    classification_report\n)\n\nfrom deep_translator import GoogleTranslator\nfrom langdetect import detect, DetectorFactory\n\n# ── Reproducibility ────────────────────────────────────────────────────────────\nDetectorFactory.seed = 42\ntorch.manual_seed(42)\nnp.random.seed(42)\n\ndevice = torch.device('cuda' if torch.cuda.is_available() else 'cpu')\n\n# ── Hyperparameters matching paper Table 3 ────────────────────────────────────\nBATCH_SIZE         = 8\nMAX_LEN            = 256\nEPOCHS_NEURAL      = 10\nEPOCHS_TRANSFORMER = 10\nLABELS             = ['Neither', 'Offensive', 'Hate']   # label 0/1/2\n\n# ── Paths ───────────────────────────────────────────────────────────────────── \nDATA_PATH = '/kaggle/input/datasets/mansoobezehra/dataset/Urdu_combined.csv'\nWORK_DIR  = '/kaggle/working'\nos.makedirs(WORK_DIR, exist_ok=True)\n\nprint(f'Device : {device}')\nprint(f'PyTorch: {torch.__version__}')\nprint(f'Dataset: {DATA_PATH}')\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-19T18:59:35.441418Z","iopub.execute_input":"2026-04-19T18:59:35.441969Z","iopub.status.idle":"2026-04-19T18:59:35.454813Z","shell.execute_reply.started":"2026-04-19T18:59:35.441927Z","shell.execute_reply":"2026-04-19T18:59:35.453985Z"}},"outputs":[{"name":"stdout","text":"Device : cuda\nPyTorch: 2.10.0+cu128\nDataset: /kaggle/input/datasets/mansoobezehra/dataset/Urdu_combined.csv\n","output_type":"stream"}],"execution_count":9},{"cell_type":"markdown","source":"---\n## Cell 2 — Preprocessing Pipeline\n\nFollows the paper (Section *Preprocessing techniques for dataset preparation*):\n1. Emoji → Urdu text  \n2. Strip Latin chars & digits  \n3. Translate Arabic fragments → Urdu  \n4. Remove tashkeel diacritics (U+064B–U+0652)  \n5. Collapse whitespace","metadata":{}},{"cell_type":"code","source":"EMOJI_DICT = {\n    '❤️': 'محبت',  '😂': 'ہنسی',    '😢': 'غم',\n    '😡': 'غصہ',   '👍': 'اچھا',     '👎': 'برا',\n    '🔥': 'آگ',    '🇵🇰': 'پاکستان', '🙏': 'دعا',\n    '🤬': 'گالی'\n}\n \n# If the API is unreachable on import the whole cell crashes.\n# Use lazy initialisation instead.\n_translator = None\ndef _get_translator():\n    global _translator\n    if _translator is None:\n        _translator = GoogleTranslator(source='ar', target='ur')\n    return _translator\n\n\ndef clean_urdu(text: str) -> str:\n    \"\"\"Full preprocessing pipeline (Hussain et al. 2025).\"\"\"\n    text = str(text).strip()\n    for em, ur in EMOJI_DICT.items():\n        text = text.replace(em, f' {ur} ')\n    text = re.sub(r'[a-zA-Z0-9]+', '', text)\n    try:\n        if len(text) > 20 and detect(text) == 'ar':\n            text = _get_translator().translate(text)\n    except Exception:\n        pass\n    text = re.sub(r'[\\u064B-\\u0652]', '', text)\n    return re.sub(r'\\s+', ' ', text).strip()\n\n\ndef load_and_prepare(path: str):\n    \"\"\"Load CSV, clean, encode labels, return 80/10/10 stratified splits.\"\"\"\n    df = pd.read_csv(path)\n    df = df[df['Label'].isin(['normal', 'offensive', 'hate'])].copy()\n    print(f'Total samples: {len(df)}')\n    print(df['Label'].value_counts().to_string())\n\n    print('\\nCleaning text (may take a few minutes)…')\n    df['Clean_Text'] = df['Comments'].apply(clean_urdu)\n    df['Label_ID']   = df['Label'].map({'normal': 0, 'offensive': 1, 'hate': 2})\n\n    tr, temp = train_test_split(df, test_size=0.20, random_state=42, stratify=df['Label_ID'])\n    vl, te   = train_test_split(temp, test_size=0.50, random_state=42, stratify=temp['Label_ID'])\n\n    print(f'\\nTrain: {len(tr)} | Val: {len(vl)} | Test: {len(te)}')\n    return tr.reset_index(drop=True), vl.reset_index(drop=True), te.reset_index(drop=True)","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-19T18:59:35.456084Z","iopub.execute_input":"2026-04-19T18:59:35.457194Z","iopub.status.idle":"2026-04-19T18:59:35.472207Z","shell.execute_reply.started":"2026-04-19T18:59:35.457166Z","shell.execute_reply":"2026-04-19T18:59:35.471375Z"}},"outputs":[],"execution_count":10},{"cell_type":"markdown","source":"---\n## Cell 3 — Evaluation & Diagnostic Utilities","metadata":{}},{"cell_type":"code","source":"def evaluate_model(model, loader, is_transformer: bool = True):\n    \"\"\"Inference over a DataLoader. Returns (y_true, y_pred, y_probs, wf1, acc).\"\"\"\n    model.eval()\n    y_true, y_pred, y_probs = [], [], []\n    with torch.no_grad():\n        for batch in loader:\n            if is_transformer:\n                ids, mask, labs = [t.to(device) for t in batch]\n                logits = model(ids, attention_mask=mask).logits\n            else:\n                ids, labs = [t.to(device) for t in batch]\n                logits = model(ids)\n            probs = F.softmax(logits, dim=1)\n            y_probs.extend(probs.cpu().numpy())\n            y_pred.extend(torch.argmax(logits, dim=1).cpu().numpy())\n            y_true.extend(labs.cpu().numpy())\n    y_true  = np.array(y_true)\n    y_pred  = np.array(y_pred)\n    y_probs = np.array(y_probs)\n    return y_true, y_pred, y_probs, f1_score(y_true, y_pred, average='weighted'), accuracy_score(y_true, y_pred)\n\n\ndef print_full_metrics(y_true, y_pred, model_name: str):\n    \"\"\"Print accuracy / precision / recall / F1 matching paper Table 6 format.\"\"\"\n    print(f\"\\n{'─'*54}\")\n    print(f\"  {model_name}\")\n    print(f\"  Accuracy  : {accuracy_score(y_true, y_pred)*100:.2f}%\")\n    print(f\"  Precision : {precision_score(y_true, y_pred, average='weighted', zero_division=0)*100:.2f}%\")\n    print(f\"  Recall    : {recall_score(y_true, y_pred, average='weighted', zero_division=0)*100:.2f}%\")\n    print(f\"  F1 Score  : {f1_score(y_true, y_pred, average='weighted')*100:.2f}%\")\n    print(f\"{'─'*54}\")\n    print(classification_report(y_true, y_pred, target_names=LABELS, zero_division=0))\n\n\ndef plot_diagnostics(y_true, y_pred, y_probs, model_name: str):\n    \"\"\"Normalised confusion matrix + per-class softmax PR curves.\"\"\"\n    fig, axes = plt.subplots(1, 2, figsize=(14, 5))\n    cm = confusion_matrix(y_true, y_pred, normalize='true')\n    sns.heatmap(cm, annot=True, fmt='.2f', cmap='Blues',\n                xticklabels=LABELS, yticklabels=LABELS, ax=axes[0])\n    axes[0].set_title(f'{model_name} — Confusion Matrix')\n    axes[0].set_ylabel('True'); axes[0].set_xlabel('Predicted')\n    for i, lbl in enumerate(LABELS):\n        p, r, _ = precision_recall_curve((y_true == i).astype(int), y_probs[:, i])\n        axes[1].plot(r, p, label=f'{lbl} (AUC={auc(r, p):.2f})')\n    axes[1].set_title(f'{model_name} — Precision-Recall Curves')\n    axes[1].set_xlabel('Recall'); axes[1].set_ylabel('Precision')\n    axes[1].legend(); axes[1].grid(alpha=0.3)\n    plt.tight_layout()\n    safe = model_name.replace(' ', '_').replace('(', '').replace(')', '')\n    plt.savefig(f'{safe}_diagnostics.png', dpi=150, bbox_inches='tight')\n    plt.show()","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-19T18:59:35.47326Z","iopub.execute_input":"2026-04-19T18:59:35.473595Z","iopub.status.idle":"2026-04-19T18:59:35.494883Z","shell.execute_reply.started":"2026-04-19T18:59:35.473557Z","shell.execute_reply":"2026-04-19T18:59:35.494113Z"}},"outputs":[],"execution_count":11},{"cell_type":"markdown","source":"---\n## Cell 4 — Model Architectures\n\n### 4A. Character-Level RNN & LSTM\n### 4B. GLLRD Parameter Groups for DAmBERT (Eq. 3)","metadata":{}},{"cell_type":"code","source":"class UrduRNN(nn.Module):\n    \"\"\"2-layer vanilla RNN with character embeddings.\"\"\"\n    def __init__(self, vocab_size, emb_dim=128, hidden_dim=256, num_layers=2):\n        super().__init__()\n        # BUG-FIX: padding_idx=0 so PAD tokens don't contribute to gradients\n        self.emb = nn.Embedding(vocab_size, emb_dim, padding_idx=0)\n        self.rnn = nn.RNN(emb_dim, hidden_dim, num_layers, batch_first=True, dropout=0.3)\n        self.fc  = nn.Linear(hidden_dim, 3)\n    def forward(self, x):\n        out, _ = self.rnn(self.emb(x))\n        return self.fc(out[:, -1, :])   # last time-step\n\n\nclass UrduLSTM(nn.Module):\n    \"\"\"3-layer LSTM with character embeddings.\"\"\"\n    def __init__(self, vocab_size, emb_dim=128, hidden_dim=256, num_layers=3):\n        super().__init__()\n        # BUG-FIX: padding_idx=0\n        self.emb  = nn.Embedding(vocab_size, emb_dim, padding_idx=0)\n        self.lstm = nn.LSTM(emb_dim, hidden_dim, num_layers, batch_first=True, dropout=0.3)\n        self.fc   = nn.Linear(hidden_dim, 3)\n    def forward(self, x):\n        _, (h, _) = self.lstm(self.emb(x))\n        return self.fc(h[-1])   # top-layer final hidden state\n\n\ndef get_gllrd_params(model, base_lr=5e-5, decay=0.95):\n    \"\"\"\n    GLLRD parameter groups (Eq. 3, Hussain et al. 2025).\n\n    Decay schedule:\n      Classifier  → base_lr\n      Layer 11    → base_lr * decay^1\n      Layer 10    → base_lr * decay^2\n      ...         → ...\n      Layer 0     → base_lr * decay^12\n      Embeddings  → base_lr * decay^13\n\n    BUG-FIX: original used `decay ** (11 - i + 1)` which equals `decay ** (12 - i)`.\n    Both are numerically identical, but the intent is now explicit for clarity.\n\n    BUG-FIX: original used `'bert' in model_path` to select backbone, but\n    'bert' appears inside 'xlm-roberta' too — fixed via hasattr check below.\n    \"\"\"\n    param_groups = [{'params': model.classifier.parameters(), 'lr': base_lr}]\n    backbone = model.bert if hasattr(model, 'bert') else model.roberta\n    for i in range(11, -1, -1):\n        param_groups.append({\n            'params': backbone.encoder.layer[i].parameters(),\n            'lr': base_lr * (decay ** (12 - i))\n        })\n    param_groups.append({\n        'params': backbone.embeddings.parameters(),\n        'lr': base_lr * (decay ** 13)\n    })\n    return param_groups","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-19T18:59:35.496289Z","iopub.execute_input":"2026-04-19T18:59:35.496511Z","iopub.status.idle":"2026-04-19T18:59:35.511422Z","shell.execute_reply.started":"2026-04-19T18:59:35.496488Z","shell.execute_reply":"2026-04-19T18:59:35.510821Z"}},"outputs":[],"execution_count":12},{"cell_type":"markdown","source":"---\n## Cell 5 — Load Dataset\n\nDataset is read from `/kaggle/input/DATASET/Urdu_combined.csv`\n(Kaggle dataset slug: **DATASET**, file: **Urdu_combined.csv**).\n","metadata":{}},{"cell_type":"code","source":"if not os.path.exists(DATA_PATH):\n    raise FileNotFoundError(\n        f\"Dataset not found at '{DATA_PATH}'.\\n\"\n        \"Add the dataset in Kaggle → + Add Data → search for your dataset \"\n        \"(slug: DATASET) so Urdu_combined.csv appears at that path.\"\n    )\n\ntr, vl, te = load_and_prepare(DATA_PATH)\nfinal_benchmarks = {}   # {model_name: test_f1_%}\nprint('\\nDataset ready — running all experiments.')\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-19T18:59:35.580915Z","iopub.execute_input":"2026-04-19T18:59:35.581649Z","iopub.status.idle":"2026-04-19T18:59:53.686552Z","shell.execute_reply.started":"2026-04-19T18:59:35.581618Z","shell.execute_reply":"2026-04-19T18:59:53.685773Z"}},"outputs":[{"name":"stdout","text":"Total samples: 16337\nLabel\nnormal       7891\noffensive    6199\nhate         2247\n\nCleaning text (may take a few minutes)…\n\nTrain: 13069 | Val: 1634 | Test: 1634\n\nDataset ready — running all experiments.\n","output_type":"stream"}],"execution_count":13},{"cell_type":"markdown","source":"---\n## Cell 6 — [1/3] Traditional ML Baselines (TF-IDF)\n\nSVM · LR · RF · Decision Tree &nbsp;|&nbsp; Paper reference: Table 6","metadata":{}},{"cell_type":"code","source":"print('\\n' + '='*60)\nprint('[1/3]  ML Baselines  (TF-IDF + sklearn)  — parallel')\nprint('='*60)\n\n# Fit TF-IDF on training data only (prevent leakage)\ntfidf = TfidfVectorizer(max_features=5000)\nX_tr  = tfidf.fit_transform(tr['Clean_Text'])\nX_vl  = tfidf.transform(vl['Clean_Text'])\nX_te  = tfidf.transform(te['Clean_Text'])\n\n# n_jobs=-1 uses all CPU cores on the estimators that support it.\nml_models = [\n    ('SVM',           SVC(probability=True, random_state=42)),\n    ('LR',            LogisticRegression(max_iter=1000, random_state=42, n_jobs=-1)),\n    ('RF',            RandomForestClassifier(n_estimators=100, random_state=42, n_jobs=-1)),\n    ('Decision Tree', DecisionTreeClassifier(random_state=42)),\n]\n\ndef _run_ml(args):\n    \"\"\"Train one ML model and return results — runs in a thread pool.\"\"\"\n    mname, clf = args\n    clf.fit(X_tr, tr['Label_ID'])\n    val_f1 = f1_score(vl['Label_ID'], clf.predict(X_vl), average='weighted') * 100\n    yp  = clf.predict(X_te)\n    ypb = clf.predict_proba(X_te)\n    tf1 = f1_score(te['Label_ID'], yp, average='weighted') * 100\n    return mname, clf, val_f1, yp, ypb, tf1\n \n# Use min(4, len) workers so we don't over-subscribe small Kaggle instances.\nn_workers = min(4, len(ml_models))\nprint(f'Launching {len(ml_models)} classifiers across {n_workers} threads...\\n')\n\nresults_ml = {}\nwith concurrent.futures.ThreadPoolExecutor(max_workers=n_workers) as pool:\n    futures = {pool.submit(_run_ml, item): item[0] for item in ml_models}\n    for fut in concurrent.futures.as_completed(futures):\n        mname, clf, val_f1, yp, ypb, tf1 = fut.result()\n        results_ml[mname] = (clf, val_f1, yp, ypb, tf1)\n        print(f'  ✓ {mname:15s}  Val F1: {val_f1:.2f}%  Test F1: {tf1:.2f}%')\n\n# Report + plots (sequential, matplotlib is not thread-safe)\nfor mname, _ in ml_models:          # preserve original order for output\n    clf, val_f1, yp, ypb, tf1 = results_ml[mname]\n    final_benchmarks[mname] = tf1\n    print_full_metrics(te['Label_ID'].values, yp, mname)\n    plot_diagnostics(te['Label_ID'].values, yp, ypb, mname)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-19T18:59:53.688243Z","iopub.execute_input":"2026-04-19T18:59:53.688507Z","iopub.status.idle":"2026-04-19T19:03:13.464171Z","shell.execute_reply.started":"2026-04-19T18:59:53.688482Z","shell.execute_reply":"2026-04-19T19:03:13.463318Z"}},"outputs":[{"name":"stdout","text":"\n============================================================\n[1/3]  ML Baselines  (TF-IDF + sklearn)  — parallel\n============================================================\nLaunching 4 classifiers across 4 threads...\n\n  ✓ LR               Val F1: 67.63%  Test F1: 66.69%\n  ✓ Decision Tree    Val F1: 58.44%  Test F1: 