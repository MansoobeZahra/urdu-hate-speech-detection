ewritten clearly.\n    \"\"\"\n    encoded = []\n    for t in texts:\n        ids = [char2idx.get(c, 1) for c in t[:MAX_LEN]]\n        ids += [0] * (MAX_LEN - len(ids))\n        encoded.append(ids)\n    return encoded\n\n\ndef make_neural_loader(split_df, shuffle=False):\n    ids = torch.tensor(char_encode(split_df['Clean_Text'].tolist()), dtype=torch.long)\n    lbs = torch.tensor(split_df['Label_ID'].tolist(), dtype=torch.long)\n    return DataLoader(TensorDataset(ids, lbs), batch_size=BATCH_SIZE, shuffle=shuffle)\n\n\n# Pre-build tensors once; each thread creates its own DataLoader view.\n_nn_ids_tr = torch.tensor(char_encode(tr['Clean_Text'].tolist()), dtype=torch.long)\n_nn_lbs_tr = torch.tensor(tr['Label_ID'].tolist(), dtype=torch.long)\n_nn_ids_vl = torch.tensor(char_encode(vl['Clean_Text'].tolist()), dtype=torch.long)\n_nn_lbs_vl = torch.tensor(vl['Label_ID'].tolist(), dtype=torch.long)\n_nn_ids_te = torch.tensor(char_encode(te['Clean_Text'].tolist()), dtype=torch.long)\n_nn_lbs_te = torch.tensor(te['Label_ID'].tolist(), dtype=torch.long)\n\ndef _make_nn_loaders():\n    \"\"\"Return fresh DataLoaders backed by the shared pre-built tensors.\"\"\"\n    tr_nn = DataLoader(TensorDataset(_nn_ids_tr, _nn_lbs_tr), batch_size=BATCH_SIZE, shuffle=True)\n    vl_nn = DataLoader(TensorDataset(_nn_ids_vl, _nn_lbs_vl), batch_size=BATCH_SIZE)\n    te_nn = DataLoader(TensorDataset(_nn_ids_te, _nn_lbs_te), batch_size=BATCH_SIZE)\n    return tr_nn, vl_nn, te_nn\n\n\ndef train_neural(arch_cls, mname):\n    \"\"\"Train one neural model; returns (mname, yt, yp, ypb, tf1, acc).\"\"\"\n    tr_nn, vl_nn, te_nn = _make_nn_loaders()\n    model     = arch_cls(VOCAB_SIZE).to(device)\n    optimizer = torch.optim.Adam(model.parameters(), lr=1e-3)\n    criterion = nn.CrossEntropyLoss()\n    best_val  = 0.0\n    ckpt      = os.path.join(WORK_DIR, f'best_{mname}.pt')\n\n    for epoch in range(EPOCHS_NEURAL):\n        model.train()\n        total_loss = 0.0\n        for bx, by in tr_nn:\n            bx, by = bx.to(device), by.to(device)\n            optimizer.zero_grad()\n            loss = criterion(model(bx), by)\n            loss.backward()\n            optimizer.step()\n            total_loss += loss.item()\n        _, _, _, vf1, vacc = evaluate_model(model, vl_nn, is_transformer=False)\n        print(f'  [{mname}] Ep {epoch+1:2d}/{EPOCHS_NEURAL} | '\n              f'Loss: {total_loss/len(tr_nn):.4f} | '\n              f'Val F1: {vf1*100:.2f}%  Acc: {vacc*100:.2f}%')\n        if vf1 > best_val:\n            best_val = vf1\n            torch.save(model.state_dict(), ckpt)\n\n    model.load_state_dict(torch.load(ckpt, map_location=device, weights_only=True))\n    yt, yp, ypb, tf1, acc = evaluate_model(model, te_nn, is_transformer=False)\n    print(f'\\n  ★ {mname} Test F1: {tf1*100:.2f}%  Acc: {acc*100:.2f}%')\n    return mname, yt, yp, ypb, tf1, acc\n\n\n# ── Parallel execution ────────────────────────────────────────────────────────\n# On a single GPU both models still share the same device, so PyTorch serialises\n# CUDA ops internally. Threading gives us overlap on the CPU-side data pipeline\n# and lets both training loops print interleaved progress — total wall time is\n# close to max(t_rnn, t_lstm) rather than t_rnn + t_lstm.\nneural_results = {}\n\nif device.type == 'cuda':\n    print('GPU detected — running RNN and LSTM in parallel threads.\\n')\n    with concurrent.futures.ThreadPoolExecutor(max_workers=2) as pool:\n        fut_rnn  = pool.submit(train_neural, UrduRNN,  'RNN')\n        fut_lstm = pool.submit(train_neural, UrduLSTM, 'LSTM')\n        for fut in concurrent.futures.as_completed([fut_rnn, fut_lstm]):\n            mname, yt, yp, ypb, tf1, acc = fut.result()\n            neural_results[mname] = (yt, yp, ypb, tf1, acc)\nelse:\n    print('CPU mode — running RNN then LSTM sequentially to avoid memory contention.\\n')\n    for arch_cls, mname in [(UrduRNN, 'RNN'), (UrduLSTM, 'LSTM')]:\n        mname, yt, yp, ypb, tf1, acc = train_neural(arch_cls, mname)\n        neural_results[mname] = (yt, yp, ypb, tf1, acc)\n\n# Report + plots (sequential — matplotlib is not thread-safe)\nfor mname in ['RNN', 'LSTM']:\n    yt, yp, ypb, tf1, acc = neural_results[mname]\n    final_benchmarks[mname] = tf1 * 100\n    print_full_metrics(yt, yp, mname)\n    plot_diagnostics(yt, yp, ypb, mname)\n","metadata":{"trusted":true,"execution":{"iopub.status.busy":"2026-04-19T19:03:13.465525Z","iopub.execute_input":"2026-04-19T19:03:13.465981Z","iopub.status.idle":"2026-04-19T19:10:41.364582Z","shell.execute_reply.started":"2026-04-19T19:03:13.46594Z","shell.execute_reply":"2026-04-19T19:10:41.36386Z"}},"outputs":[{"name":"stdout","text":"\n============================================================\n[2/3]  Neural Baselines  (char-level RNN & LSTM)  — parallel\n============================================================\nVocabulary size: 377 characters\nGPU detected — running RNN and LSTM in parallel threads.\n\n  [RNN] Ep  1/10 | Loss: 1.0214 | Val F1: 39.62%  Acc: 46.88%\n  [RNN] Ep  2/10 | Loss: 1.0138 | Val F1: 41.04%  Acc: 47.18%\n  [LSTM] Ep  1/10 | Loss: 0.9967 | Val F1: 35.73%  Acc: 49.14%\n  [RNN] Ep  3/10 | Loss: 1.0182 | Val F1: 40.49%  Acc: 46.63%\n  [RNN] Ep  4/10 | Loss: 1.0259 | Val F1: 28.29%  Acc: 31.52%\n  [RNN] Ep  5/10 | Loss: 1.0198 | Val F1: 38.69%  Acc: 41.55%\n  [LSTM] Ep  2/10 | Loss: 0.9950 | Val F1: 31.45%  Acc: 48.29%\n  [RNN] Ep  6/10 | Loss: 1.0216 | Val F1: 38.58%  Acc: 41.43%\n  [RNN] Ep  7/10 | Loss: 1.0193 | Val F1: 31.45%  Acc: 48.29%\n  [RNN] Ep  8/10 | Loss: 1.0177 | Val F1: 38.58%  Acc: 41.43%\n  [LSTM] Ep  3/10 | Loss: 0.9936 | Val F1: 31.45%  Acc: 48.29%\n  [RNN] Ep  9/10 | Loss: 1.0225 | Val F1: 31.45%  Acc: 48.29%\n  [RNN] Ep 10/10 | Loss: 1.0223 | Val F1: 31.45%  Acc: 48.29%\n\n  ★ RNN Test F1: 44.16%  Acc: 50.06%\n  [LSTM] Ep  4/10 | Loss: 0.9931 | Val F1: 31.45%  Acc: 48.29%\n  [LSTM] Ep  5/10 | Loss: 0.9935 | Val F1: 31.45%  Acc: 48.29%\n  [LSTM] Ep  6/10 | Loss: 0.9927 | Val F1: 31.45%  Acc: 48.29%\n  [LSTM] Ep  7/10 | Loss: 0.9928 | Val F1: 31.45%  Acc: 48.29%\n  [LSTM] Ep  8/10 | Loss: 0.9925 | Val F1: 31.45%  Acc: 48.29%\n  [LSTM] Ep  9/10 | Loss: 0.9926 | Val F1: 31.45%  Acc: 48.29%\n  [LSTM] Ep 10/10 | Loss: 0.9926 | Val F1: 31.45%  Acc: 48.29%\n\n  ★ LSTM Test F1: 35.98%  Acc: 49.33%\n\n──────────────────────────────────────────────────────\n  RNN\n  Accuracy  : 50.06%\n  Precision : 42.26%\n  Recall    : 50.06%\n  F1 Score  : 44.16%\n──────────────────────────────────────────────────────\n              precision    recall  f1-score   support\n\n     Neither       0.52      0.79      0.63       790\n   Offensive       0.46      0.31      0.37       620\n        Hate       0.00      0.00      0.00       224\n\n    accuracy                           0.50      1634\n   macro avg       0.32      0.37      0.33      1634\nweighted avg       0.42      0.50      0.44      1634\n\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1400x500 with 3 Axes>","image/png":"\n"},"metadata":{}},{"name":"stdout","text":"\n──────────────────────────────────────────────────────\n  LSTM\n  Accuracy  : 49.33%\n  Precision : 43.96%\n  Recall    : 49.33%\n  F1 Score  : 35.98%\n──────────────────────────────────────────────────────\n              precision    recall  f1-score   support\n\n     Neither       0.49      0.97      0.65       790\n   Offensive       0.53      0.07      0.12       620\n        Hate       0.00      0.00      0.00       224\n\n    accuracy                           0.49      1634\n   macro avg       0.34      0.34      0.26      1634\nweighted avg       0.44      0.49      0.36      1634\n\n","output_type":"stream"},{"output_type":"display_data","data":{"text/plain":"<Figure size 1400x500 with 3 Axes>","image/png":"\n"},"metadata":{}}],"execution_count":15},{"cell_type":"markdown","source":"---\n## Cell 8 — [3/3] Transformer Fine-tuning (XLM-RoBERTa & DAmBERT)\n\n**XLM-RoBERTa**: fixed LR=2e-5, no adaptive loss (Table 3)  \n**DAmBERT** (`bert-base-multilingual-cased`): GLLRD + inverse-frequency adaptive loss","metadata":{}},{"cell_type":"code","source":"print('\\n' + '='*60)\nprint('[3/3]  Transformer Fine-tuning')\nprint('='*60)\n\n# Suppress noisy HF weight-loading report\nfrom transformers import logging as hf_logging\nhf_logging.set_verbosity_error()\n\n# Adaptive class weights — Eq. 5: w_i = N / n_i\nclass_counts  = tr['Label_ID'].value_counts().sort_index().values\nclass_weights = torch.tensor(len(tr) / class_counts, dtype=torch.float).to(device)\nprint(f'Class weights (Neither/Offensive/Hate): {class_weights.cpu().numpy().round(3)}')\n\n\ndef make_transformer_loader(split_df, tokenizer, shuffle=False):\n    enc = tokenizer(\n        split_df['Clean_Text'].tolist(),\n        truncation=True, padding='max_length',\n        max_length=MAX_LEN, return_tensors='pt'\n    )\n    lbs = torch.tensor(split_df['Label_ID'].tolist(), dtype=torch.long)\n    ds  = TensorDataset(enc['input_ids'], enc['attention_mask'], lbs)\n    return DataLoader(ds, batch_size=BATCH_SIZE, shuffle=shuffle)\n\n\ndef run_transformer(display_name, model_path, use_gllrd=False):\n    safe = display_name.replace(' ', '_').replace('(', '').replace(')', '')\n    ckpt = os.path.join(WORK_DIR, f'best_{safe}.pt')\n    print(f'\\nFine-tuning {display_name}  [{model_path}]  gllrd={use_gllrd}')\n\n    is_mbert = 'multilingual' in model_path or \\\n               ('bert' in model_path and 'roberta' not in model_path)\n    if is_mbert:\n        tokenizer = BertTokenizer.from_pretrained(model_path)\n        model = BertForSequenceClassification.from_pretrained(\n            model_path, num_labels=3, ignore_mismatched_sizes=True).to(device)\n    else:\n        tokenizer = XLMRobertaTokenizer.from_pretrained(model_path)\n        model = XLMRobertaForSequenceClassification.from_pretrained(\n            model_path, num_labels=3, ignore_mismatched_sizes=True).to(device)\n\n    tr_ldr = make_transformer_loader(tr, tokenizer, shuffle=True)\n    vl_ldr = make_transformer_loader(vl, tokenizer)\n    te_ldr = make_transformer_loader(te, tokenizer)\n\n    if use_gllrd:\n        optimizer = AdamW(get_gllrd_params(model, base_lr=5e-5), weight_decay=0.01)\n        criterion = nn.CrossEntropyLoss(weight=class_weights)\n    else:\n        optimizer = AdamW(model.parameters(), lr=2e-5, weight_decay=0.01)\n        criterion = nn.CrossEntropyLoss()\n\n    scheduler = get_linear_schedule_with_warmup(\n        optimizer,\n        num_warmup_steps=500,\n        num_training_steps=len(tr_ldr) * EPOCHS_TRANSFORMER\n    )\n\n    best_val = 0.0\n    for epoch in range(EPOCHS_TRANSFORMER):\n        model.train()\n        total_loss = 0.0\n        for x_ids, x_mask, y_lbl in tr_ldr:\n            x_ids, x_mask, y_lbl = x_ids.to(device), x_mask.to(device), y_lbl.to(device)\n            optimizer.zero_grad()\n            loss = criterion(model(x_ids, attention_mask=x_mask).logits, y_lbl)\n            loss.backward()\n            torch.nn.utils.clip_grad_norm_(model.parameters(), max_norm=1.0)\n            optimizer.step()\n            scheduler.step()\n            total_loss += loss.item()\n        _, _, _, vf1, vacc = evaluate_model(model, vl_ldr, is_transformer=True)\n        print(f'  {display_name} Ep {epoch+1:2d}/{EPOCHS_TRANSFORMER} | '\n              f'Loss: {total_loss/len(tr_ldr):.4f} | '\n              f'Val F1: {vf1*100:.2f}%  Acc: {vacc*100:.2f}%')\n        if vf1 > best_val:\n            best_val = vf1\n            torch.save(model.state_dict(), ckpt)\n\n    model.load_state_dict(torch.load(ckpt, map_location=device, weights_only=True))\n\n    yt, yp, ypb, tf1, acc = evaluate_model(model, te_ldr, is_transformer=True)\n    final_benchmarks[display_name] = tf1 * 100\n    print(f'\\n  ★ {display_name} Test F1: {tf1*100:.2f}%  Acc: {acc*100:.2f}%')\n    print_full_metrics(yt, yp, display_name)\n    plot_diagnostics(yt, yp, ypb, display_name)\n\n\n# XLM-RoBERTa: standard fine-tunin